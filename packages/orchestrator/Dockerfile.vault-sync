FROM node:22-alpine

RUN npm install -g obsidian-headless

# Note: node:22-alpine already has group `node` at GID 1000.
# Runner containers also use GID 1000, so files with group `node` are accessible.

WORKDIR /vault

COPY <<'ENTRYPOINT' /entrypoint.sh
#!/bin/sh
set -e
umask 007

# Build password flag conditionally (omit entirely if no E2EE)
PASSWORD_FLAG=""
if [ -n "$VAULT_E2EE_PASSWORD" ]; then
  PASSWORD_FLAG="--password $VAULT_E2EE_PASSWORD"
fi

# Setup sync
ob sync-setup \
  --vault "$VAULT_NAME" \
  --path "/vault/$VAULT_NAME" \
  $PASSWORD_FLAG \
  --device-name "runner-${SIDECAR_ID:-$$}"

# Fix permissions for shared volume access
chown -R root:node "/vault/$VAULT_NAME"
chmod -R g+rwX "/vault/$VAULT_NAME"

# Run continuous sync
exec ob sync --continuous --path "/vault/$VAULT_NAME"
ENTRYPOINT
RUN chmod +x /entrypoint.sh

CMD ["/entrypoint.sh"]
