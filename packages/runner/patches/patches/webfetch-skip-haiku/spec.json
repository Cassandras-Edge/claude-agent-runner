{
  "id": "webfetch-skip-haiku",
  "disabled": true,
  "description": "Skip Haiku summarization in WebFetch — return raw markdown directly",
  "target": "both",
  "tested_versions": ["2.1.63"],
  "steps": [
    {
      "type": "find_replace",
      "id": "skip_haiku",
      "find": "else C=await ufB(R,$,A.signal,_,J)",
      "replace": "else C=$",
      "mode": "literal",
      "pad_to_length": true
    }
  ]
}
