/* === CLAUDIAN PATCH: sdk-ipc — Unix socket for SDK NDJSON protocol === */
if(!globalThis.__sdkIpcStarted){globalThis.__sdkIpcStarted=true;
globalThis.__sdkIpcClients=new Set();
/* At this point in C3$, n (wake fn), W (outbound queue = {{QUEUE_VAR}}),
   ED (prompt enqueue, module-level), and _ (IO bridge) are all in scope. */
/* Tap outbound queue: broadcast every event to socket clients */
(function(){var _origEnq={{QUEUE_VAR}}.enqueue.bind({{QUEUE_VAR}});
{{QUEUE_VAR}}.enqueue=function(_item){_origEnq(_item);
if(globalThis.__sdkIpcClients.size===0)return;
var _line;try{_line=JSON.stringify(_item)+"\n"}catch(e){return}
for(var _c of globalThis.__sdkIpcClients){try{_c.write(_line)}catch(e){}}};
})();
/* Socket server: accepts SDK NDJSON protocol */
(function(){var _sockPath=typeof process!=="undefined"&&process.env&&process.env.CLAUDE_SDK_IPC_SOCKET;
if(!_sockPath)return;
var _net;try{_net=require("net")}catch(e){try{_net=require("node:net")}catch(e2){return}}
var _fs;try{_fs=require("fs")}catch(e){try{_fs=require("node:fs")}catch(e2){return}}
var _crypto;try{_crypto=require("crypto")}catch(e){try{_crypto=require("node:crypto")}catch(e2){}}
try{_fs.unlinkSync(_sockPath)}catch(e){}
var _pendingCtrl=new Map();
var _srv=_net.createServer(function(conn){
globalThis.__sdkIpcClients.add(conn);
/* Send session_init on connect */
try{var _sid={{SESSION_FN}}();
conn.write(JSON.stringify({type:"system",subtype:"init",session_id:_sid,uuid:(_crypto?_crypto.randomUUID():"sdk-ipc-init")})+"\n");
}catch(e){}
conn.on("close",function(){globalThis.__sdkIpcClients.delete(conn)});
conn.on("error",function(){globalThis.__sdkIpcClients.delete(conn)});
var _buf="";
conn.on("data",function(chunk){_buf+=chunk.toString();var lines=_buf.split("\n");_buf=lines.pop()||"";
for(var i=0;i<lines.length;i++){if(!lines[i].trim())continue;
try{var msg=JSON.parse(lines[i]);_handleMsg(msg,conn)}
catch(e){conn.write(JSON.stringify({type:"error",error:String(e)})+"\n")}}});
});
_srv.listen(_sockPath,function(){try{_fs.chmodSync(_sockPath,0o777)}catch(e){}});
_srv.on("error",function(e){});
function _handleMsg(msg,conn){
/* User message — inject through ED() + n(), TUI renders it */
if(msg.type==="user"){
var _content=msg.message&&msg.message.content;
var _val=_content;
if(Array.isArray(_content)){_val=_content}
else if(typeof _content==="string"){_val=_content}
else if(msg.message&&typeof msg.message==="string"){_val=msg.message}
if(!_val)return;
ED({mode:"prompt",value:_val,uuid:msg.uuid||(_crypto?_crypto.randomUUID():"sdk-"+Date.now()),skipSlashCommands:!!msg.skipSlashCommands,priority:msg.priority||"next"});
try{n()}catch(e){}
return;
}
/* Control request — currently ack immediately.
   Full routing (interrupt via abort controller, setModel, etc.) will be added
   as the runner integration matures. */
if(msg.type==="control_request"){
var _reqId=msg.request_id||(_crypto?_crypto.randomUUID():"ctrl-"+Date.now());
var _req=msg.request||msg;
if(_req.subtype==="interrupt"){
/* Abort the current turn's abort controller (J in C3$ scope) */
try{if(typeof J!=="undefined"&&J&&!J.signal.aborted)J.abort()}catch(e){}
}
conn.write(JSON.stringify({type:"control_response",response:{subtype:"success",request_id:_reqId,response:{}}})+"\n");
return;
}
/* Ping/health check */
if(msg.type==="ping"){
conn.write(JSON.stringify({type:"pong",session_id:{{SESSION_FN}}()})+"\n");
return;
}
}
})()}
