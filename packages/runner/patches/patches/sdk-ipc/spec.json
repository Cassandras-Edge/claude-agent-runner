{
  "id": "sdk-ipc",
  "description": "Unix socket for SDK NDJSON protocol — works in both interactive and print modes",
  "target": "js-only",
  "tested_versions": ["2.1.81"],
  "steps": [
    {
      "type": "extract",
      "id": "session_fn",
      "scope": "global",
      "anchor": "queue-operation",
      "pattern": "let [\\w$]+=([\\w$]+)\\(\\),[\\w$]+=\\{type:\"queue-operation\"",
      "store_as": "SESSION_FN"
    },
    {
      "type": "extract",
      "id": "enqueue_later_fn",
      "scope": "global",
      "anchor": "priority:_.priority??\"later\"",
      "pattern": "\\}function ([\\w$]+)\\([\\w$]+\\)\\{[\\w$]+\\.push\\(\\{\\.\\.\\.[\\w$]+,priority:[\\w$]+\\.priority\\?\\?\"later\"",
      "store_as": "LATER_FN"
    },
    {
      "type": "insert_before",
      "id": "inject_sdk_ipc",
      "marker": "function {{LATER_FN}}(",
      "code_file": "patch-code.js.tmpl"
    }
  ]
}
