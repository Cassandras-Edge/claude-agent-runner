# Claude API (OAuth) — supports multiple tokens (comma-separated) for round-robin per session
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat-...
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat-token1,sk-ant-oat-token2,sk-ant-oat-token3

# Git (for cloning private repos)
GIT_TOKEN=ghp_...
# or
GITHUB_TOKEN=ghp_...

# Orchestrator config (optional)
# PORT=8080
# WS_PORT=8081
# RUNNER_IMAGE=claude-runner:latest
# DOCKER_NETWORK=claude-net
# IDLE_TIMEOUT_MS=300000
# MESSAGE_TIMEOUT_MS=600000
# CLEANUP_RUNNERS_ON_EXIT=false
# MAX_ACTIVE_SESSIONS=8

# Persistence (optional — defaults shown)
# DB_PATH=/app/data/orchestrator.db
# SESSIONS_VOLUME=claude-sessions
# SESSIONS_PATH=/data/sessions
